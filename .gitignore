# ── Binary model / resource files (large, not version-controlled) ─────────
# ESCO taxonomy index and skill embeddings (~400 MB)
resume-studio-reviewer/src/main/resources/taxonomy/

# OpenNLP pre-trained models (POS tagger, tokenizer, NER, sentence detector)
resume-studio-reviewer/src/main/resources/nlp/

# Generic binary model guard — catches any .bin file added under resources
resume-studio-reviewer/src/main/resources/**/*.bin

# ── Secrets / local config ────────────────────────────────────────────────
# Raw .env files — never commit
*.env
*.env.*

# Plaintext secret files — never commit
application-secret.properties

# NOTE: application-local.properties and application-prod.properties are
# intentionally tracked — they contain only Jasypt ENC() ciphertext, not
# plaintext secrets. The master key (JASYPT_ENCRYPTOR_PASSWORD) is the only
# secret that must never be committed.

# ── Docs / conversation exports ───────────────────────────────────────────
claude-conversation.md

# ── IntelliJ bin output ───────────────────────────────────────────────────
bin/
